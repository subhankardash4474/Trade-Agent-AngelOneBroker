# Copy to `.env` and fill in real values. Never commit `.env` to git.
# The agent will load these at startup and use them instead of the
# placeholder fields in config.yaml.

# ─── AngelOne SmartAPI (canonical broker as of 2026-05-08) ───
# Get these from https://smartapi.angelbroking.com/ → My Apps
# TOTP secret: enable TOTP under AngelOne web → Profile → Settings → TOTP.
ANGELONE_API_KEY=
ANGELONE_API_SECRET=
ANGELONE_CLIENT_ID=
ANGELONE_PASSWORD=
ANGELONE_TOTP_SECRET=

# ─── Email alerts (Resend) ───
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxx
ALERT_SENDER=Trading Agent <onboarding@resend.dev>
ALERT_RECIPIENT=you@example.com

# ─── SMTP fallback (only if provider=smtp) ───
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_PASSWORD=YOUR_APP_PASSWORD
