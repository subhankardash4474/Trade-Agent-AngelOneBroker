# Copy to `.env` and fill in real values. Never commit `.env` to git.
# The agent will load these at startup and use them instead of the
# placeholder fields in config.yaml.

# ─── AngelOne SmartAPI (canonical broker as of 2026-05-08) ───
# Get these from https://smartapi.angelbroking.com/ → My Apps
# TOTP secret: enable TOTP under AngelOne web → Profile → Settings → TOTP.
ANGELONE_API_KEY=
ANGELONE_API_SECRET=
ANGELONE_CLIENT_ID=
ANGELONE_PASSWORD=
ANGELONE_TOTP_SECRET=

# ─── Email alerts (Resend) ───
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxx
ALERT_SENDER=Trading Agent <onboarding@resend.dev>
ALERT_RECIPIENT=you@example.com

# ─── SMTP fallback (only if provider=smtp) ───
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_PASSWORD=YOUR_APP_PASSWORD

# ─── SSL verification (corporate-network behaviour) ───
# DEFAULT (unset or "true") = SSL verification is DISABLED. This keeps the
# daemon working out-of-the-box behind corporate proxies (Amdocs / Infosys
# etc.) that inject self-signed root certs.
#
# On a CLOUD VM (OCI / AWS / DigitalOcean / any public host) set this to
# "false" -- the cloud .env.production.example already does so by default.
# Disabling cert verification on a public box is a real security hole.
TRADER_DISABLE_SSL_VERIFY=true
