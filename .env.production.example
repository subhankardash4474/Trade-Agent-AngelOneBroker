# =============================================================================
# .env template for CLOUD / PRODUCTION deployment
# =============================================================================
# Copy to `.env` ON THE CLOUD VM ONLY. Never commit a real .env to git.
#
# On the VM:    cp .env.production.example .env
#               nano .env                # paste real secrets
#               chmod 600 .env           # owner-read-only
#               chown trader:trader .env # if running as the trader user
#               docker compose up -d
#
# Local-dev knobs that DO NOT belong on cloud are documented below.
# =============================================================================

# --- AngelOne SmartAPI (canonical broker since 2026-05-08) --------------------
# Get from https://smartapi.angelbroking.com/ -> My Apps
# CRITICAL: the VM's public IP must be set as "Primary Static IP" in the
# AngelOne SmartAPI dashboard BEFORE any order endpoint will work (AG7002).
ANGELONE_API_KEY=
ANGELONE_API_SECRET=
ANGELONE_CLIENT_ID=
ANGELONE_PASSWORD=
ANGELONE_TOTP_SECRET=

# --- Email alerts (Resend) ---------------------------------------------------
RESEND_API_KEY=
ALERT_SENDER=Trading Agent <onboarding@resend.dev>
ALERT_RECIPIENT=

# --- SMTP fallback (optional, only if monitoring.alerts.email.provider=smtp) -
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_PASSWORD=

# --- SSL verification --------------------------------------------------------
# CLOUD = explicitly enable SSL cert verification (the codebase historically
# defaults to "verification off" to support corporate-proxy laptops; on a
# public cloud VM that default is a security regression, so we override it
# here). Keep this as "false" -- it means "do NOT disable verification".
TRADER_DISABLE_SSL_VERIFY=false

# --- Broker mode safety lock (optional) --------------------------------------
# Belt-and-suspenders: even if config.yaml says broker.mode=live, this env
# var will force paper mode if set to "1". Useful during the cloud burn-in
# week -- remove (or set to 0) after Stage 0/1/2 pass from the cloud IP.
# TRADER_FORCE_PAPER=1
