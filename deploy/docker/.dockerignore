# Don't ship runtime state into the image
logs/
data/*.db
data/*.db-*
models/*.pkl
models/*.pt
.venv/
venv/
.env
.env.*

# Don't ship dev-only artefacts
.git/
.github/
.cursor/
.pytest_cache/
.mypy_cache/
.ruff_cache/
__pycache__/
*.pyc
*.pyo
.coverage
htmlcov/

# Don't ship docs / IDE files
docs/
.vscode/
.idea/

# Don't ship the legacy backtest dirs
backtest_run_*/
